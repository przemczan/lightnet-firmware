{
  "openapi": "3.0.0",
  "info": {
    "title": "Lightnet",
    "version": "1.0.0"
  },
  "paths": {
    "/api/appearance": {
      "get": {
        "summary": "Get Appearance",
        "parameters": [],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      },
      "patch": {
        "summary": "Update Appearance",
        "parameters": [],
        "responses": {
          "202": {
            "description": "Accepted — validated; applied to panels on the main loop"
          }
        },
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "example": {
                  "brightness": 128,
                  "baseColors": [
                    "#FF0000",
                    "#00FF00",
                    "#0000FF"
                  ],
                  "palette": "Lava"
                }
              }
            }
          }
        }
      }
    },
    "/api/palettes": {
      "get": {
        "summary": "List Palettes",
        "parameters": [],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "schemaVersion": { "type": "integer" },
                      "name": { "type": "string" },
                      "builtin": { "type": "boolean" },
                      "stops": {
                        "type": "array",
                        "items": {
                          "type": "array",
                          "items": {}
                        }
                      }
                    }
                  },
                  "example": [
                    {
                      "schemaVersion": 1,
                      "name": "Rainbow",
                      "builtin": true,
                      "stops": [[0, "#FF0000"], [255, "#FF0000"]]
                    },
                    {
                      "schemaVersion": 1,
                      "name": "Base colors",
                      "builtin": true,
                      "stops": [[0, "#FF0000"], [128, "#00FF00"], [255, "#0000FF"]]
                    }
                  ]
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Create Palette",
        "parameters": [],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "example": { "name": "my-palette" }
              }
            }
          },
          "409": {
            "description": "name_exists"
          }
        },
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "example": {
                  "schemaVersion": 1,
                  "name": "my-palette",
                  "stops": [
                    [0, "#000000"],
                    [128, "#FF4400"],
                    [255, "#FFFFFF"]
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/api/palettes/{{name}}": {
      "get": {
        "summary": "Get Palette By Name",
        "parameters": [
          {
            "name": "name",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "404": {
            "description": "not_found"
          }
        }
      },
      "put": {
        "summary": "Update Palette Stops",
        "parameters": [
          {
            "name": "name",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          },
          "403": {
            "description": "cannot_overwrite_builtin"
          },
          "404": {
            "description": "not_found"
          }
        },
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "example": {
                  "schemaVersion": 1,
                  "name": "my-palette",
                  "stops": [
                    [0, "#000000"],
                    [255, "#FFFFFF"]
                  ]
                }
              }
            }
          }
        }
      },
      "delete": {
        "summary": "Delete Palette By Name",
        "parameters": [
          {
            "name": "name",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "No Content"
          },
          "403": {
            "description": "cannot_delete_builtin"
          },
          "404": {
            "description": "not_found"
          }
        }
      }
    },
    "/api/scenes": {
      "description": "Scene library stored in /data/scenes.db (SceneStore). HTTP bodies use scene JSON; list entries return id, name, layerCount, duration.",
      "post": {
        "summary": "Create Scene",
        "parameters": [],
        "responses": {
          "200": {
            "description": "OK"
          },
          "422": {
            "description": "id: not allowed"
          }
        },
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "example": {
                  "schemaVersion": 1,
                  "name": "sunset",
                  "loop": true,
                  "layers": []
                }
              }
            }
          }
        }
      },
      "patch": {
        "summary": "Update Scene",
        "parameters": [],
        "responses": {
          "200": {
            "description": "OK"
          },
          "404": {
            "description": "not_found"
          },
          "422": {
            "description": "id: required"
          }
        },
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "example": {
                  "schemaVersion": 1,
                  "id": "abcd1234",
                  "name": "sunset",
                  "loop": true,
                  "layers": []
                }
              }
            }
          }
        }
      },
      "get": {
        "summary": "List Scenes",
        "parameters": [],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/scenes/{{id}}": {
      "get": {
        "summary": "Get Scene By Id",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      },
      "delete": {
        "summary": "Delete Scene By Name",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/scenes/play/one-shot": {
      "post": {
        "summary": "Play Inline Scene (stored as '@one-shot', then played by name)",
        "parameters": [],
        "responses": {
          "202": {
            "description": "Accepted — validated; the play/trigger work was queued onto the main loop"
          },
          "409": {
            "description": "system_off — controller is powered off; turn it on via POST /api/state/power first"
          }
        },
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "example": {
                  "schemaVersion": 1,
                  "name": "inline-scene",
                  "loop": true,
                  "layers": []
                }
              }
            }
          }
        }
      }
    },
    "/api/scenes/play": {
      "post": {
        "summary": "Replay Last-Played Scene (stored scene by name, or the one-shot scene)",
        "parameters": [],
        "responses": {
          "202": {
            "description": "Accepted — validated; the play/trigger work was queued onto the main loop"
          },
          "404": {
            "description": "no_last_played_scene — nothing has been played yet"
          },
          "409": {
            "description": "system_off — controller is powered off; turn it on via POST /api/state/power first"
          }
        }
      }
    },
    "/api/scenes/{{id}}/play": {
      "post": {
        "summary": "Play Stored Scene By Name",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "202": {
            "description": "Accepted — validated; the play/trigger work was queued onto the main loop"
          },
          "409": {
            "description": "system_off — controller is powered off; turn it on via POST /api/state/power first"
          }
        }
      }
    },
    "/api/scenes/stop": {
      "post": {
        "summary": "Stop Scene Playback",
        "parameters": [],
        "responses": {
          "202": {
            "description": "Accepted — stop queued onto the main loop"
          }
        }
      }
    },
    "/api/scenes/speed": {
      "post": {
        "summary": "Set Scene Playback Speed",
        "parameters": [],
        "responses": {
          "202": {
            "description": "Accepted — speed change queued onto the main loop"
          }
        },
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "example": {
                  "speed": 2.0
                }
              }
            }
          }
        }
      }
    },
    "/api/animations/play": {
      "post": {
        "summary": "Play One-Shot Animation",
        "parameters": [],
        "responses": {
          "202": {
            "description": "Accepted — validated; the play/trigger work was queued onto the main loop"
          },
          "409": {
            "description": "system_off — controller is powered off; turn it on via POST /api/state/power first"
          }
        },
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "example": {
                  "group": 250,
                  "panels": "all",
                  "type": "PULSE",
                  "color": "#FF0000",
                  "brightnessFrom": 0,
                  "brightnessTo": 255,
                  "duration": 600,
                  "params": [64, 128, 64]
                }
              }
            }
          }
        }
      }
    },
    "/api/animations/trigger": {
      "post": {
        "summary": "Trigger Reactive Animation",
        "parameters": [],
        "responses": {
          "202": {
            "description": "Accepted — validated; the play/trigger work was queued onto the main loop"
          },
          "409": {
            "description": "system_off — controller is powered off; turn it on via POST /api/state/power first"
          }
        },
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "example": {
                  "group": 1,
                  "value": 200
                }
              }
            }
          }
        }
      }
    },
    "/api/firmware/panels": {
      "post": {
        "summary": "Upload And Flash Panel Firmware",
        "parameters": [],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/firmware/status": {
      "get": {
        "summary": "Get Firmware Flash Status",
        "parameters": [],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/topology": {
      "get": {
        "summary": "Get Topology Config (logical root + tags)",
        "parameters": [],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "example": {
                    "logicalRoot": 5,
                    "tags": { "1": ["accent", "left"], "5": ["accent"] }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/topology/root": {
      "put": {
        "summary": "Set Logical Root Panel",
        "parameters": [],
        "responses": {
          "202": { "description": "Accepted — applied to a playing scene on the main loop" },
          "422": { "description": "logicalRoot out of range" }
        },
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "example": { "logicalRoot": 5 }
              }
            }
          }
        }
      }
    },
    "/api/panel-tags": {
      "get": {
        "summary": "Get Panel Tag Map",
        "parameters": [],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "example": { "1": ["accent", "left"], "5": ["accent"] }
                }
              }
            }
          }
        }
      },
      "put": {
        "summary": "Replace Panel Tag Map",
        "parameters": [],
        "responses": {
          "200": { "description": "OK" },
          "422": { "description": "invalid tag map" }
        },
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "example": { "1": ["accent", "left"], "5": ["accent"] }
              }
            }
          }
        }
      }
    },
    "/api/panels": {
      "get": {
        "summary": "List Panels",
        "parameters": [],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/panels/edges": {
      "get": {
        "summary": "Get Panel Edges",
        "parameters": [],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/panels/{{panelAddress}}/on": {
      "put": {
        "summary": "Set Panel On State",
        "parameters": [
          {
            "name": "{panelAddress",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "202": {
            "description": "Accepted — packet queued onto the main loop"
          }
        },
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "value": {
                    "type": "integer",
                    "enum": [0, 1],
                    "description": "0 = off, 1 = on"
                  }
                },
                "required": ["value"],
                "example": {
                  "value": 1
                }
              }
            }
          }
        }
      }
    },
    "/api/panels/{{panelAddress}}/color": {
      "put": {
        "summary": "Set Panel Color",
        "parameters": [
          {
            "name": "{panelAddress",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "202": {
            "description": "Accepted — packet queued onto the main loop"
          }
        },
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "example": {
                  "color": "#FF0000"
                }
              }
            }
          }
        }
      }
    },
    "/api/configuration": {
      "get": {
        "summary": "Get Configuration",
        "parameters": [],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "example": {
                  "powerStateOnBoot": 0
                }
              }
            }
          }
        }
      },
      "patch": {
        "summary": "Update Configuration",
        "parameters": [],
        "responses": {
          "200": {
            "description": "OK"
          },
          "422": {
            "description": "powerStateOnBoot out of range (must be 0, 1, or 2)"
          }
        },
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "powerStateOnBoot": {
                    "type": "integer",
                    "enum": [0, 1, 2],
                    "description": "0=ALWAYS_ON, 1=ALWAYS_OFF, 2=LAST_STATE"
                  }
                },
                "required": ["powerStateOnBoot"],
                "example": {
                  "powerStateOnBoot": 2
                }
              }
            }
          }
        }
      }
    },
    "/api/state": {
      "get": {
        "summary": "Get App State",
        "parameters": [],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "example": {
                  "isOn": true,
                  "lastPlayedSceneId": "abcd1234",
                  "lastPlayedSceneIsStored": true,
                  "playing": true,
                  "speed": 1.0
                }
              }
            }
          }
        }
      }
    },
    "/api/state/power": {
      "post": {
        "summary": "Set Power State",
        "parameters": [],
        "responses": {
          "202": {
            "description": "Accepted — state flipped; panel on/off effects applied on the main loop",
            "content": {
              "application/json": {
                "example": {
                  "isOn": false
                }
              }
            }
          }
        },
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "isOn": {
                    "type": "boolean",
                    "description": "true = panels on. false = stop animations and turn all panels off."
                  }
                },
                "required": ["isOn"],
                "example": {
                  "isOn": false
                }
              }
            }
          }
        }
      }
    }
  }
}
